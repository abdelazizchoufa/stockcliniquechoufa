@model PurchaseOrderCreateViewModel
@{
    ViewData["Title"] = "Nouvelle commande";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="mb-4">
            <p class="eyebrow mb-1">Commande fournisseur</p>
            <h1 class="h2 mb-0">Creer une commande d'approvisionnement</h1>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="OrderNumber" class="form-label"></label>
                            <input asp-for="OrderNumber" class="form-control" />
                            <span asp-validation-for="OrderNumber" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SupplierId" class="form-label"></label>
                            <select asp-for="SupplierId" asp-items="Model.Suppliers" class="form-select">
                                <option value="">Selectionner</option>
                            </select>
                            <span asp-validation-for="SupplierId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="OrderDate" class="form-label"></label>
                            <input asp-for="OrderDate" class="form-control" />
                            <span asp-validation-for="OrderDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ExpectedDeliveryDate" class="form-label"></label>
                            <input asp-for="ExpectedDeliveryDate" class="form-control" />
                            <span asp-validation-for="ExpectedDeliveryDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <hr class="my-4" />
                    <h2 class="h5 mb-3">Lignes de commande</h2>

                    @for (var i = 0; i < Model.Lines.Count; i++)
                    {
                        <div class="row g-3 align-items-end mb-2">
                            <div class="col-md-6">
                                <label class="form-label">Article @(i + 1)</label>
                                <select asp-for="Lines[i].StockItemId" asp-items="Model.StockItems" class="form-select">
                                    <option value="">Selectionner</option>
                                </select>
                                <span asp-validation-for="Lines[i].StockItemId" class="text-danger"></span>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Quantite</label>
                                <input asp-for="Lines[i].QuantityOrdered" class="form-control" />
                                <span asp-validation-for="Lines[i].QuantityOrdered" class="text-danger"></span>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Prix unitaire</label>
                                <input asp-for="Lines[i].UnitPrice" class="form-control" />
                                <span asp-validation-for="Lines[i].UnitPrice" class="text-danger"></span>
                            </div>
                        </div>
                    }

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">Enregistrer la commande</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Retour</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
