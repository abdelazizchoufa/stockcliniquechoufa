@model SupplierDeleteViewModel
@{
    ViewData["Title"] = "Supprimer fournisseur";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <p class="eyebrow mb-2">Confirmation</p>
                <h1 class="h3">Supprimer ce fournisseur ?</h1>

                <div class="mt-4 mb-4">
                    <strong>@Model.Name</strong><br />
                    <span class="text-muted">@Model.ContactName</span><br />
                    <span class="text-muted">Commandes associees : @Model.OrderCount</span>
                </div>

                @if (!Model.CanDelete)
                {
                    <div class="alert alert-warning mb-4">@Model.BlockingReason</div>
                    <a asp-action="Index" class="btn btn-outline-secondary">Retour</a>
                }
                else
                {
                    <div class="alert alert-danger mb-4">Cette action est irreversible.</div>
                    <form asp-action="ConfirmDeleteSupplier" method="post" class="d-flex gap-2">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger">Confirmer la suppression</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
                    </form>
                }
            </div>
        </div>
    </div>
</div>
