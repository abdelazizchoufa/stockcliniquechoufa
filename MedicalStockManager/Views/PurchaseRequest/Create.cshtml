@model PurchaseRequestCreateViewModel
@{
    ViewData["Title"] = "Nouvelle demande d'achat";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <p class="eyebrow mb-1">Demande d'achat</p>
        <h1 class="h2 mb-0">Nouvelle demande</h1>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index">Annuler</a>
</div>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <h5 class="fw-semibold mb-3"><i class="bi bi-file-text me-2 text-muted"></i>Informations generales</h5>
            <div class="mb-3">
                <label asp-for="Justification" class="form-label"></label>
                <textarea asp-for="Justification" class="form-control" rows="3"
                          placeholder="Ex: Rupture de stock prevue dans les 7 prochains jours, besoins urgents pour le service..."></textarea>
                <span asp-validation-for="Justification" class="text-danger small"></span>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header fw-semibold d-flex align-items-center gap-2">
            <i class="bi bi-list-ul"></i> Articles demandes
            <span class="text-muted small fw-normal ms-1">(remplissez les lignes dont vous avez besoin)</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0" id="linesTable">
                    <thead>
                        <tr>
                            <th style="width:30%">Article</th>
                            <th style="width:10%">Qte</th>
                            <th style="width:10%">Unite</th>
                            <th style="width:15%">Prix unitaire (DA)</th>
                            <th style="width:12%">Total estime</th>
                            <th>Justification</th>
                        </tr>
                    </thead>
                    <tbody>
                    @for (int i = 0; i < Model.Lines.Count; i++)
                    {
                        <tr class="line-row">
                            <td>
                                <select name="Lines[@i].StockItemId" class="form-select form-select-sm stock-select mb-1"
                                        onchange="fillLabel(this, @i)">
                                    <option value="">-- Article existant (optionnel) --</option>
                                    @foreach (var item in Model.StockItems)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                </select>
                                <input type="text" name="Lines[@i].ItemLabel" class="form-control form-control-sm label-input"
                                       placeholder="Ou saisissez une designation libre" />
                            </td>
                            <td>
                                <input type="number" name="Lines[@i].RequestedQuantity" value="1" min="1"
                                       class="form-control form-control-sm qty-input" onchange="updateTotal(@i)" />
                            </td>
                            <td>
                                <input type="text" name="Lines[@i].Unit" value="unite"
                                       class="form-control form-control-sm" />
                            </td>
                            <td>
                                <input type="number" name="Lines[@i].EstimatedUnitPrice" value="0" min="0" step="0.01"
                                       class="form-control form-control-sm price-input" onchange="updateTotal(@i)" />
                            </td>
                            <td>
                                <span class="fw-semibold total-cell" id="total-@i">0 DA</span>
                            </td>
                            <td>
                                <input type="text" name="Lines[@i].Notes" class="form-control form-control-sm"
                                       placeholder="Optionnel" />
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer d-flex justify-content-between align-items-center">
            <span class="text-muted small">Total estime : <strong id="grandTotal">0 DA</strong></span>
        </div>
    </div>

    <div class="d-flex gap-3">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-send me-1"></i> Soumettre la demande
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
    </div>
</form>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
// Pre-fill label from selected stock item
const stockNames = {
    @foreach (var item in Model.StockItems)
    {
        @Html.Raw($"\"{item.Value}\": \"{item.Text.Split('(')[0].Trim()}\",")
    }
};

function fillLabel(select, i) {
    const labelInput = document.querySelectorAll('.label-input')[i];
    if (select.value && stockNames[select.value]) {
        labelInput.value = stockNames[select.value];
    }
    updateTotal(i);
}

function updateTotal(i) {
    const rows = document.querySelectorAll('.line-row');
    const qty   = parseFloat(rows[i].querySelector('.qty-input').value) || 0;
    const price = parseFloat(rows[i].querySelector('.price-input').value) || 0;
    const total = qty * price;
    document.getElementById('total-' + i).textContent = total.toLocaleString('fr-FR') + ' DA';
    updateGrandTotal();
}

function updateGrandTotal() {
    const totals = [...document.querySelectorAll('.total-cell')]
        .map(el => parseFloat(el.textContent.replace(/\s/g,'').replace('DA','').replace(',','.')) || 0);
    const grand = totals.reduce((a, b) => a + b, 0);
    document.getElementById('grandTotal').textContent = grand.toLocaleString('fr-FR') + ' DA';
}
</script>
}
