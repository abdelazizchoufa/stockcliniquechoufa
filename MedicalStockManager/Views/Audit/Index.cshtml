@model AuditLogViewModel
@{
    ViewData["Title"] = "Journal d'audit";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <p class="eyebrow mb-1">Audit</p>
        <h1 class="h2 mb-0">Journal des actions utilisateur</h1>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        @if (!Model.Logs.Any())
        {
            <p class="text-muted mb-0">Aucune action auditee pour le moment.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Utilisateur</th>
                            <th>Action</th>
                            <th>Entite</th>
                            <th>Reference</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var log in Model.Logs)
                    {
                        <tr>
                            <td>@log.OccurredAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@log.Username</td>
                            <td>@log.Action</td>
                            <td>@log.EntityType</td>
                            <td>@(string.IsNullOrWhiteSpace(log.EntityId) ? "-" : log.EntityId)</td>
                            <td>@(string.IsNullOrWhiteSpace(log.Details) ? "-" : log.Details)</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
