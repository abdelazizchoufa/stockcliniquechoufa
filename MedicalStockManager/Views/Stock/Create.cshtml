@model StockItemFormViewModel
@{
    ViewData["Title"] = "Nouvel article";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="mb-4">
            <p class="eyebrow mb-1">Creation</p>
            <h1 class="h2 mb-0">Ajouter un article au stock</h1>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Reference" class="form-label"></label>
                            <input asp-for="Reference" class="form-control" />
                            <span asp-validation-for="Reference" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Department" class="form-label"></label>
                            <select asp-for="Department" asp-items="Html.GetEnumSelectList<Department>()" class="form-select"></select>
                            <span asp-validation-for="Department" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Unit" class="form-label"></label>
                            <input asp-for="Unit" class="form-control" />
                            <span asp-validation-for="Unit" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CurrentQuantity" class="form-label"></label>
                            <input asp-for="CurrentQuantity" class="form-control" />
                            <span asp-validation-for="CurrentQuantity" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AlertThreshold" class="form-label"></label>
                            <input asp-for="AlertThreshold" class="form-control" />
                            <span asp-validation-for="AlertThreshold" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ExpirationDate" class="form-label"></label>
                            <input asp-for="ExpirationDate" class="form-control" />
                            <span asp-validation-for="ExpirationDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">Enregistrer</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Retour</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
