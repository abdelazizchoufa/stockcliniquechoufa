@model ServiceDirectoryViewModel
@using MedicalStockManager.Models
@{
    ViewData["Title"] = "Services";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <p class="eyebrow mb-1">Referentiel</p>
        <h1 class="h2 mb-0">Services</h1>
    </div>
</div>

<div class="row g-4">
    @if (User.IsInRole(AppRole.Administrateur) || User.IsInRole(AppRole.GestionnaireStock))
    {
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header fw-semibold">Nouveau service</div>
                <div class="card-body">
                    <form asp-action="AddService" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <div class="mb-3">
                            <label asp-for="NewService.Name" class="form-label"></label>
                            <input asp-for="NewService.Name" class="form-control" />
                            <span asp-validation-for="NewService.Name" class="text-danger"></span>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-plus-lg me-1"></i> Ajouter
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }

    <div class="@(User.IsInRole(AppRole.Administrateur) || User.IsInRole(AppRole.GestionnaireStock) ? "col-lg-8" : "col-12")">
        <div class="card border-0 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-semibold">Liste des services</span>
                <span class="badge bg-secondary rounded-pill">@Model.Services.Count</span>
            </div>
            @if (!Model.Services.Any())
            {
                <div class="card-body text-center text-muted py-5">
                    <i class="bi bi-diagram-3 fs-1 d-block mb-3 opacity-25"></i>
                    <p class="mb-0">Aucun service enregistre.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Service</th>
                                <th class="text-end">Articles lies</th>
                                @if (User.IsInRole(AppRole.Administrateur) || User.IsInRole(AppRole.GestionnaireStock))
                                {
                                    <th class="text-end"></th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var service in Model.Services)
                        {
                            <tr>
                                <td><strong>@service.Name</strong></td>
                                <td class="text-end">@service.ItemCount</td>
                                @if (User.IsInRole(AppRole.Administrateur) || User.IsInRole(AppRole.GestionnaireStock))
                                {
                                    <td class="text-end">
                                        @if (service.ItemCount > 0)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="Service utilise par des articles">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <form asp-action="DeleteService" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@service.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Supprimer ce service ?');">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
