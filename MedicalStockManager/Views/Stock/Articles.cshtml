@model StockIndexViewModel
@{
    ViewData["Title"] = "Articles";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <p class="eyebrow mb-1">Referentiel</p>
        <h1 class="h2 mb-0">Articles</h1>
    </div>
    @if (User.IsInRole(AppRole.Administrateur) || User.IsInRole(AppRole.GestionnaireStock))
    {
        <a class="btn btn-primary" asp-action="Create">
            <i class="bi bi-plus-lg me-1"></i> Nouvel article
        </a>
    }
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="d-flex gap-2">
            <input name="search" value="@Model.Filter.SearchTerm" class="form-control"
                   placeholder="Rechercher par nom ou reference..." />
            <button type="submit" class="btn btn-outline-primary">
                <i class="bi bi-search"></i>
            </button>
            @if (!string.IsNullOrWhiteSpace(Model.Filter.SearchTerm))
            {
                <a asp-action="Articles" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i>
                </a>
            }
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Liste des articles</span>
        <span class="badge bg-secondary rounded-pill">@Model.Items.Count</span>
    </div>
    @if (!Model.Items.Any())
    {
        <div class="card-body text-center text-muted py-5">
            <i class="bi bi-capsule fs-1 d-block mb-3 opacity-25"></i>
            <p class="mb-0">Aucun article trouve.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Reference</th>
                        <th>Designation</th>
                        <th>Service</th>
                        <th>Unite</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="text-muted small font-monospace">@item.Reference</td>
                        <td><strong>@item.Name</strong></td>
                        <td><span class="department-badge">@(item.Service?.Name ?? "-")</span></td>
                        <td class="text-muted small">@item.Unit</td>
                        <td class="text-end">
                            <div class="d-flex gap-1 justify-content-end">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@item.Id">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (User.IsInRole(AppRole.Administrateur) || User.IsInRole(AppRole.GestionnaireStock))
                                {
                                    <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
