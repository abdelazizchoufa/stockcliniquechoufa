@model StockItemDetailsViewModel
@{
    Layout = "_PrintLayout";
    ViewData["Title"] = "Impression fiche article";
}

<div class="print-header mb-4 d-flex justify-content-between align-items-start">
    <div>
        <h1 class="h2 mb-1">Fiche article</h1>
        <p class="mb-0">@Model.Item.Name - @Model.Item.Reference</p>
    </div>
    <div class="no-print d-flex gap-2">
        <button onclick="window.print()" class="btn btn-outline-secondary btn-sm">Imprimer</button>
        <button id="btnPdf" class="btn btn-primary btn-sm">Telecharger PDF</button>
    </div>
</div>

<section class="row g-3 mb-4">
    <div class="col-3">
        <div class="metric-card">
            <span class="metric-label">Service</span>
            <strong class="metric-value fs-3">@(Model.Item.Service?.Name ?? "-")</strong>
        </div>
    </div>
    <div class="col-3">
        <div class="metric-card">
            <span class="metric-label">Stock</span>
            <strong class="metric-value fs-3">@Model.Item.CurrentQuantity</strong>
        </div>
    </div>
    <div class="col-3">
        <div class="metric-card">
            <span class="metric-label">Seuil</span>
            <strong class="metric-value fs-3">@Model.Item.AlertThreshold</strong>
        </div>
    </div>
    <div class="col-3">
        <div class="metric-card">
            <span class="metric-label">Expiration</span>
            <strong class="metric-value fs-3">@(Model.Item.ExpirationDate?.ToString("dd/MM/yyyy") ?? "-")</strong>
        </div>
    </div>
</section>

<h2 class="h4">Historique des mouvements</h2>
<table class="table table-sm">
    <thead>
        <tr>
            <th>Date</th>
            <th>Type</th>
            <th>Quantite</th>
            <th>N° Lot</th>
            <th>Observation</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var movement in Model.Movements)
    {
        <tr>
            <td>@movement.Date.ToString("dd/MM/yyyy")</td>
            <td>@movement.MovementType</td>
            <td>@movement.Quantity</td>
            <td>@(string.IsNullOrWhiteSpace(movement.BatchNumber) ? "-" : movement.BatchNumber)</td>
            <td>@(string.IsNullOrWhiteSpace(movement.Notes) ? "-" : movement.Notes)</td>
        </tr>
    }
    </tbody>
</table>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
document.getElementById('btnPdf')?.addEventListener('click', () => {
    const el = document.querySelector('body');
    html2pdf().set({
        margin: 10,
        filename: '@("fiche-article-" + Model.Item.Reference.Replace("/","-").Replace(" ","-") + ".pdf")',
        image: { type: 'jpeg', quality: 0.98 },
        html2canvas: { scale: 2 },
        jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
    }).from(el).save();
});
</script>
}
