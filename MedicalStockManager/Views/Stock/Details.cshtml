@model StockItemDetailsViewModel
@{
    ViewData["Title"] = "Detail article";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="page-header-block">
        <p class="eyebrow mb-1">Suivi article</p>
        <h1 class="h2 mb-1">@Model.Item.Name</h1>
        <p class="text-muted mb-0">@Model.Item.Reference</p>
        <div class="mt-2 d-flex flex-wrap gap-2">
            <span class="department-badge">@(Model.Item.Service?.Name ?? "-")</span>
            @if (Model.Item.IsLowStock)
            {
                <span class="badge text-bg-warning">Stock bas</span>
            }
            @if (Model.Item.ExpirationDate is not null && Model.Item.ExpirationDate <= DateTime.Today.AddMonths(3))
            {
                <span class="badge text-bg-danger">Expiration proche</span>
            }
        </div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-action="Print" asp-route-id="@Model.Item.Id">Imprimer / PDF</a>
        @if (Model.CanEdit)
        {
            <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Item.Id">Modifier</a>
            <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Item.Id">Supprimer</a>
        }
        <a class="btn btn-outline-secondary" asp-action="Index">Retour au stock</a>
    </div>
</div>

<section class="row g-4 mb-4">
    <div class="col-lg-4">
        <div class="metric-card">
            <span class="metric-label">Stock actuel</span>
            <strong class="metric-value">@Model.Item.CurrentQuantity</strong>
            <span>@Model.Item.Unit</span>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="metric-card @(Model.Item.IsLowStock ? "warning" : string.Empty)">
            <span class="metric-label">Seuil d'alerte</span>
            <strong class="metric-value">@Model.Item.AlertThreshold</strong>
            <span>@Model.Item.Unit</span>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="metric-card">
            <span class="metric-label">Expiration</span>
            <strong class="metric-value fs-3">@(Model.Item.ExpirationDate?.ToString("dd/MM/yyyy") ?? "-")</strong>
            <span>@(Model.Item.IsLowStock ? "Reapprovisionnement conseille" : "Niveau correct")</span>
        </div>
    </div>
</section>

@if (Model.Batches.Any())
{
    <section class="mb-4">
        <div class="card border-0 shadow-sm dashboard-card">
            <div class="card-body p-4">
                <div class="section-heading mb-3">
                    <div>
                        <p class="section-kicker">Localisation</p>
                        <h2 class="h4 mb-0">Stock par Magasin et par Lot (FEFO)</h2>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Emplacement</th>
                                <th>N° Lot</th>
                                <th>Date d'expiration</th>
                                <th>Quantité restante</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var batch in Model.Batches)
                            {
                                var days = (batch.ExpirationDate - DateTime.Today).Days;
                                var badgeClass = days < 0 ? "text-bg-dark" : days <= 30 ? "text-bg-danger" : days <= 90 ? "text-bg-warning" : "text-bg-success";
                                
                                <tr>
                                    <td>
                                        <span class="fw-bold">@batch.Location?.Name</span>
                                    </td>
                                    <td><code>@batch.BatchNumber</code></td>
                                    <td>
                                        @batch.ExpirationDate.ToString("dd/MM/yyyy")
                                        <span class="badge @badgeClass ms-2">
                                            @(days < 0 ? "Périmé" : $"{days} j")
                                        </span>
                                    </td>
                                    <td><strong>@batch.Quantity @Model.Item.Unit</strong></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>
}

<section class="row g-4">
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100 dashboard-card">
            <div class="card-body p-4">
                <div class="section-heading mb-3">
                    <div>
                        <p class="section-kicker">Operation</p>
                        <h2 class="h4 mb-0">Nouveau mouvement</h2>
                    </div>
                </div>

                @if (User.IsInRole(AppRole.Administrateur) || User.IsInRole(AppRole.GestionnaireStock))
                {
                    <form asp-action="AddMovement" method="post">
                        <input asp-for="NewMovement.StockItemId" type="hidden" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="NewMovement.MovementType" class="form-label"></label>
                            <select asp-for="NewMovement.MovementType" asp-items="Html.GetEnumSelectList<MovementType>()" class="form-select" id="movementTypeSelect"></select>
                            <span asp-validation-for="NewMovement.MovementType" class="text-danger"></span>
                        </div>

                        <div class="mb-3" id="locationField">
                            <label asp-for="NewMovement.LocationId" class="form-label"></label>
                            <select asp-for="NewMovement.LocationId" asp-items="Model.Locations" class="form-select">
                            </select>
                            <span asp-validation-for="NewMovement.LocationId" class="text-danger"></span>
                        </div>

                        <div class="mb-3 text-bg-light p-2 rounded" id="destinationField" style="display:none;">
                            <label asp-for="NewMovement.DestinationLocationId" class="form-label"></label>
                            <select asp-for="NewMovement.DestinationLocationId" asp-items="Model.Locations" class="form-select">
                                <option value="">--- Selectionner ---</option>
                            </select>
                            <span asp-validation-for="NewMovement.DestinationLocationId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewMovement.Quantity" class="form-label"></label>
                            <input asp-for="NewMovement.Quantity" class="form-control" />
                            <span asp-validation-for="NewMovement.Quantity" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewMovement.Date" class="form-label"></label>
                            <input asp-for="NewMovement.Date" class="form-control" />
                            <span asp-validation-for="NewMovement.Date" class="text-danger"></span>
                        </div>

                        <div class="row" id="batchExpirationFields">
                            <div class="col-md-6 mb-3">
                                <label asp-for="NewMovement.BatchNumber" class="form-label"></label>
                                <input asp-for="NewMovement.BatchNumber" class="form-control" placeholder="Laisser vide = auto" />
                                <span asp-validation-for="NewMovement.BatchNumber" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="NewMovement.ExpirationDate" class="form-label"></label>
                                <input asp-for="NewMovement.ExpirationDate" class="form-control" />
                                <span asp-validation-for="NewMovement.ExpirationDate" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewMovement.Notes" class="form-label"></label>
                            <textarea asp-for="NewMovement.Notes" class="form-control" rows="2"></textarea>
                            <span asp-validation-for="NewMovement.Notes" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Enregistrer le mouvement</button>
                    </form>
                }
                else
                {
                    <p class="text-muted mb-0">Ton role permet la consultation de l'historique, mais pas l'ajout de mouvements.</p>
                }
                
                <script>
                    document.addEventListener("DOMContentLoaded", function () {
                        const typeSelect = document.getElementById("movementTypeSelect");
                        const destField = document.getElementById("destinationField");
                        const batchExpFields = document.getElementById("batchExpirationFields");
                        const locLabel = document.querySelector('label[for="NewMovement_LocationId"]');

                        function updateForm() {
                            const val = typeSelect.value;
                            // 1=Entree, 2=Sortie, 3=Ajustement, 4=Transfert
                            if (val === "1") {
                                destField.style.display = "none";
                                batchExpFields.style.display = "flex";
                                locLabel.innerText = "Emplacement de reception";
                            } else if (val === "4") {
                                destField.style.display = "block";
                                batchExpFields.style.display = "none";
                                locLabel.innerText = "Emplacement source";
                            } else {
                                destField.style.display = "none";
                                batchExpFields.style.display = "none";
                                locLabel.innerText = "Emplacement concerné";
                            }
                        }

                        if (typeSelect) {
                            typeSelect.addEventListener("change", updateForm);
                            updateForm();
                        }
                    });
                </script>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card border-0 shadow-sm h-100 dashboard-card">
            <div class="card-body p-4">
                <div class="section-heading mb-3">
                    <div>
                        <p class="section-kicker">Tracabilite</p>
                        <h2 class="h4 mb-0">Historique des mouvements</h2>
                    </div>
                    <span class="pill-note">@Model.Movements.Count mouvement(s)</span>
                </div>

                <form method="get" class="row g-2 mb-3">
                    <input type="hidden" name="id" value="@Model.Item.Id" />
                    <div class="col-sm-4">
                        <input type="date" name="filter.DateFrom" value="@Model.Filter.DateFrom?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" placeholder="Du" />
                    </div>
                    <div class="col-sm-4">
                        <input type="date" name="filter.DateTo" value="@Model.Filter.DateTo?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" placeholder="Au" />
                    </div>
                    <div class="col-sm-3">
                        <select name="filter.MovementType" class="form-select form-select-sm">
                            <option value="">Tous les types</option>
                            @foreach (MovementType t in Enum.GetValues(typeof(MovementType)))
                            {
                                <option value="@((int)t)" selected="@(Model.Filter.MovementType == t ? "selected" : null)">@t</option>
                            }
                        </select>
                    </div>
                    <div class="col-sm-1">
                        <button type="submit" class="btn btn-sm btn-primary w-100">OK</button>
                    </div>
                </form>

                @if (Model.Filter.DateFrom.HasValue || Model.Filter.DateTo.HasValue || Model.Filter.MovementType.HasValue)
                {
                    <a asp-action="Details" asp-route-id="@Model.Item.Id" class="btn btn-sm btn-outline-secondary mb-2">Reinitialiser les filtres</a>
                }

                @if (!Model.Movements.Any())
                {
                    <p class="text-muted mb-0">Aucun mouvement pour ces criteres.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Type</th>
                                    <th>Qte</th>
                                    <th>N° Lot</th>
                                    <th>Observation</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var movement in Model.Movements)
                            {
                                <tr>
                                    <td>@movement.Date.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @if (movement.MovementType == MovementType.Entree)
                                        {
                                            <span class="badge text-bg-success">Entree</span>
                                        }
                                        else if (movement.MovementType == MovementType.Sortie)
                                        {
                                            <span class="badge text-bg-danger">Sortie</span>
                                        }
                                        else if (movement.MovementType == MovementType.Transfert)
                                        {
                                            <span class="badge text-bg-info">Transfert</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-secondary">Ajustement</span>
                                        }
                                    </td>
                                    <td>@movement.Quantity</td>
                                    <td>@(string.IsNullOrWhiteSpace(movement.BatchNumber) ? "-" : movement.BatchNumber)</td>
                                    <td>@(string.IsNullOrWhiteSpace(movement.Notes) ? "-" : movement.Notes)</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
