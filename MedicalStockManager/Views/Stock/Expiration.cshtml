@if (!Model.ExpiredItems.Any() && !Model.ExpiringIn7Days.Any() && !Model.ExpiringIn30Days.Any() && !Model.ExpiringIn90Days.Any())
{
    <div class="alert alert-success">Aucun article n'a de date de peremption proche ou depassee.</div>
}
