    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-info text-dark fw-semibold">
            Expiration dans 90 jours (@Model.ExpiringIn90Days.Count)
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead><tr><th>Article</th><th>Service</th><th>Expiration</th><th>Jours restants</th><th>Stock</th><th></th></tr></thead>
