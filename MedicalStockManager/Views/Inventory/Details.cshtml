@model MedicalStockManager.Models.InventorySession
@{
    ViewData["Title"] = "Detail inventaire";
    var totalVariances = Model.Lines.Count(l => l.Variance != 0);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <p class="eyebrow mb-1">Inventaire</p>
        <h1 class="h2 mb-0">@Model.Title</h1>
        <p class="text-muted">@Model.Date.ToString("dd/MM/yyyy") — @Model.CreatedBy</p>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index">Retour</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="metric-card">
            <span class="metric-label">Articles comptes</span>
            <strong class="metric-value">@Model.Lines.Count</strong>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card @(totalVariances > 0 ? "warning" : "")">
            <span class="metric-label">Articles avec ecart</span>
            <strong class="metric-value">@totalVariances</strong>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <span class="metric-label">Ecart positif total</span>
            <strong class="metric-value">+@Model.Lines.Where(l => l.Variance > 0).Sum(l => l.Variance)</strong>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card danger">
            <span class="metric-label">Ecart negatif total</span>
            <strong class="metric-value">@Model.Lines.Where(l => l.Variance < 0).Sum(l => l.Variance)</strong>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Article</th>
                    <th>Service</th>
                    <th>Stock theorique</th>
                    <th>Stock compte</th>
                    <th>Ecart</th>
                    <th>Observation</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var line in Model.Lines.OrderBy(l => l.StockItem?.Service != null ? l.StockItem.Service.Name : "").ThenBy(l => l.StockItem?.Name))
            {
                <tr class="@(line.Variance != 0 ? (line.Variance < 0 ? "table-danger" : "table-warning") : "")">
                    <td>
                        <strong>@(line.StockItem?.Name ?? "?")</strong><br/>
                        <span class="text-muted small">@(line.StockItem?.Reference ?? "")</span>
                    </td>
                    <td>@(line.StockItem?.Service?.Name ?? "-")</td>
                    <td>@line.TheoreticalQuantity</td>
                    <td>@line.CountedQuantity</td>
                    <td>
                        @if (line.Variance == 0)
                        {
                            <span class="badge text-bg-success">0</span>
                        }
                        else if (line.Variance > 0)
                        {
                            <span class="badge text-bg-primary">+@line.Variance</span>
                        }
                        else
                        {
                            <span class="badge text-bg-danger">@line.Variance</span>
                        }
                    </td>
                    <td>@(string.IsNullOrWhiteSpace(line.Notes) ? "-" : line.Notes)</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
